{
  "name": "ultracode-for-copilot",
  "displayName": "Ultracode for Copilot",
  "description": "Ultracode effort mode for Copilot Chat — Claude Code-style deep reasoning with manifest, planning, and self-review.",
  "icon": "resources/icon.png",
  "version": "0.6.2",
  "publisher": "Vizards",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nolanrpg/ultracode-for-copilot"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "ultracode",
    "copilot",
    "github copilot",
    "copilot chat",
    "effort",
    "thinking",
    "reasoning",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "ultracode",
        "name": "Ultracode",
        "description": "Claude Code-style deep reasoning with manifest, planning, and self-review."
      }
    ],
    "commands": [
      {
        "command": "ultracode-copilot.showLogs",
        "title": "%ultracode-copilot.command.showLogs%"
      },
      {
        "command": "ultracode-copilot.openSettings",
        "title": "%ultracode-copilot.command.openSettings%"
      },
      {
        "command": "ultracode-copilot.showBudget",
        "title": "%ultracode-copilot.command.showBudget%"
      },
      {
        "command": "ultracode-copilot.resetBudget",
        "title": "%ultracode-copilot.command.resetBudget%"
      }
    ],
    "walkthroughs": [
      {
        "id": "ultracodeGettingStarted",
        "title": "%ultracode-copilot.walkthrough.title%",
        "description": "%ultracode-copilot.walkthrough.description%",
        "steps": [
          {
            "id": "chooseEffort",
            "title": "%ultracode-copilot.walkthrough.chooseEffort.title%",
            "description": "%ultracode-copilot.walkthrough.chooseEffort.description%",
            "media": {
              "markdown": "resources/walkthrough/show-models.md"
            }
          },
          {
            "id": "configureManifest",
            "title": "%ultracode-copilot.walkthrough.configureManifest.title%",
            "description": "%ultracode-copilot.walkthrough.configureManifest.description%",
            "media": {
              "markdown": "resources/walkthrough/advanced-settings.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%ultracode-copilot.config.title%",
      "properties": {
        "ultracode-copilot.effort.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%ultracode-copilot.config.effort.enabled%"
        },
        "ultracode-copilot.effort.maxReflectionRounds": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "%ultracode-copilot.config.effort.maxReflectionRounds%"
        },
        "ultracode-copilot.effort.budgetWarningThreshold": {
          "type": "number",
          "default": 0.8,
          "minimum": 0,
          "maximum": 1,
          "description": "%ultracode-copilot.config.effort.budgetWarningThreshold%"
        },
        "ultracode-copilot.effort.showReflection": {
          "type": "boolean",
          "default": false,
          "description": "%ultracode-copilot.config.effort.showReflection%"
        },
        "ultracode-copilot.manifest.path": {
          "type": "string",
          "default": "AGENTS.md",
          "description": "%ultracode-copilot.config.manifest.path%"
        },
        "ultracode-copilot.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumItemLabels": [
            "%ultracode-copilot.config.debugMode.minimal.label%",
            "%ultracode-copilot.config.debugMode.metadata.label%",
            "%ultracode-copilot.config.debugMode.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%ultracode-copilot.config.debugMode.minimal.description%",
            "%ultracode-copilot.config.debugMode.metadata.description%",
            "%ultracode-copilot.config.debugMode.verbose.description%"
          ],
          "markdownDescription": "%ultracode-copilot.config.debugMode.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "vscode:prepublish": "npm run compile",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "oxlint",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "package": "vsce package"
  }
}
